server {
    listen 443 ssl;
    listen [::]:443 ssl;

    server_name eap-it33.motoppdemo.nl;

    ssl_certificate /etc/letsencrypt/live/eap-it33.motoppdemo.nl/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/eap-it33.motoppdemo.nl/privkey.pem;

    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;


    location /api-dev/ {
        proxy_pass http://eap-backend-dev:8000;
    }

    location /api-test/ {
        proxy_pass http://eap-backend-test:8000;
    }

    location /api/ {
        proxy_pass http://eap-backend-prod:8000;
    }


    location /dev/ {
        proxy_pass http://eap-frontend-dev:3000/;
    }

    location /test/ {
        proxy_pass http://eap-frontend-test:3000/;
    }

    location / {
        proxy_pass http://eap-frontend-prod:3000/;

    }

    location /playwright {
        alias /playwright-report/;
        index index.html;
        auth_basic           "Restricted - Development team only";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }

    location /api-test/docs {
        auth_basic "Restricted - Development team only";
        auth_basic_user_file /etc/nginx/.htpasswd;

        proxy_pass http://eap-backend-test:8000/docs;
    }

    location /api/docs {
    deny all;
    return 403;
    }

    location /uptime-report {
        alias /uptime-report/;
        index index.html;
        auth_basic           "Restricted - Development team only";
        auth_basic_user_file /etc/nginx/.htpasswd;
    }
}

server {
    listen 80;
    listen [::]:80;

    server_name eap-it33.motoppdemo.nl;

    return 301 https://$host$request_uri;
}

